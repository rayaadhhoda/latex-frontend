{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spartan Write",
  "version": "0.1.0",
  "identifier": "dev.vivekraman.spartanwrite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Spartan Write",
        "width": 1280,
        "height": 800,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["spartan-write"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/spartan-write-sidecar",
      "bin/tectonic"
    ]
  }
}
